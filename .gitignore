# Node (if/when tests land)
node_modules/
package-lock.json

# Generated by scripts/build_bundle.mjs (CLI version of sub-tab #23 Export bundle).
# The CLI defaults to writing into the repo root, but the output is reproducible
# from the script so it doesn't belong in version control.
/bundle.tsv
/bundle.json

# Generated by scripts/build_static.mjs (build-time pre-built snapshots that the
# Export bundle page links to). Reproducible from `npm run snapshot`; CI can
# emit these as artefacts. Don't commit the heavy generated files.
/static/snapshots/
